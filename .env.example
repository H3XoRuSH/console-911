# Google Gemini API Key for Scenario Generation and LLM Fallback dialogue
# Get a free key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# DeepSeek API Key for paid ultra-low cost LLM Fallbacks and Scenario Generation
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Development Mode (set to 'Y' to enable local JSON filesystem cache instead of Upstash Redis)
DEV_MODE=

# Preview Mode (set to 'Y' to enable preview debug playlist tools in main menu)
PREVIEW_MODE=

# Upstash Redis Configuration for Leaderboard and Dialogue Caching (Production)
# Create a free Redis database at https://upstash.com/
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here
